{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "COPILOT_CLI=1 python .claude/hooks/session-start.py --copilot-cli",
        "powershell": "$env:COPILOT_CLI='1'; python .claude/hooks/session-start.py --copilot-cli"
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "COPILOT_CLI=1 python .claude/hooks/session-end.py --copilot-cli",
        "powershell": "$env:COPILOT_CLI='1'; python .claude/hooks/session-end.py --copilot-cli"
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "COPILOT_CLI=1 python .claude/hooks/inject-context.py --copilot-cli",
        "powershell": "$env:COPILOT_CLI='1'; python .claude/hooks/inject-context.py --copilot-cli"
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "COPILOT_CLI=1 python .claude/hooks/track-work.py --copilot-cli",
        "powershell": "$env:COPILOT_CLI='1'; python .claude/hooks/track-work.py --copilot-cli"
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": "COPILOT_CLI=1 python .claude/hooks/on-error.py --copilot-cli",
        "powershell": "$env:COPILOT_CLI='1'; python .claude/hooks/on-error.py --copilot-cli"
      }
    ]
  }
}
