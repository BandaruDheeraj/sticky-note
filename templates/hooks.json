{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "COPILOT_CLI=1 python .claude/hooks/session-start.py",
        "powershell": "$env:COPILOT_CLI='1'; python .claude/hooks/session-start.py"
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "COPILOT_CLI=1 python .claude/hooks/session-end.py",
        "powershell": "$env:COPILOT_CLI='1'; python .claude/hooks/session-end.py"
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "COPILOT_CLI=1 python .claude/hooks/inject-context.py",
        "powershell": "$env:COPILOT_CLI='1'; python .claude/hooks/inject-context.py"
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "COPILOT_CLI=1 python .claude/hooks/track-work.py",
        "powershell": "$env:COPILOT_CLI='1'; python .claude/hooks/track-work.py"
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": "COPILOT_CLI=1 python .claude/hooks/on-error.py",
        "powershell": "$env:COPILOT_CLI='1'; python .claude/hooks/on-error.py"
      }
    ]
  }
}
